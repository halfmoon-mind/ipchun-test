{
  "name": "ipchun",
  "private": true,
  "scripts": {
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate": "pnpm --filter @ipchun/server exec prisma migrate dev",
    "db:seed": "pnpm --filter @ipchun/server exec prisma db seed",
    "dev:server": "docker compose up -d && turbo dev --filter=@ipchun/server",
    "dev:server:prod": "NODE_ENV=production turbo dev --filter=@ipchun/server",
    "dev:mobile": "pnpm --filter @ipchun/mobile start",
    "dev:admin": "turbo dev --filter=@ipchun/admin",
    "dev:web": "turbo dev --filter=@ipchun/web",
    "dev:web:prod": "NEXT_PUBLIC_API_URL=https://api.ipchun.live turbo dev --filter=@ipchun/web",
    "build:server": "turbo build --filter=@ipchun/server",
    "build:admin": "turbo build --filter=@ipchun/admin",
    "build:web": "turbo build --filter=@ipchun/web",
    "deploy:web": "pnpm --filter @ipchun/web run deploy",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "autoparse": "tsx tools/autoparse/index.ts"
  },
  "devDependencies": {
    "prettier": "^3.5.0",
    "turbo": "^2.9.3",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.6.0"
}
