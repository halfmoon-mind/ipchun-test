{
  "name": "ipchun",
  "private": true,
  "scripts": {
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate": "pnpm --filter @ipchun/server exec prisma migrate dev",
    "db:seed": "pnpm --filter @ipchun/server exec prisma db seed",
    "dev:server": "docker compose up -d && pnpm --filter @ipchun/shared build && pnpm --filter @ipchun/server dev",
    "dev:server:prod": "pnpm --filter @ipchun/shared build && NODE_ENV=production pnpm --filter @ipchun/server dev",
    "dev:mobile": "pnpm --filter @ipchun/mobile start",
    "dev:admin": "pnpm --filter @ipchun/admin dev",
    "build:server": "pnpm --filter @ipchun/server build",
    "build:admin": "pnpm --filter @ipchun/admin build",
    "dev:web": "pnpm --filter @ipchun/web dev",
    "build:web": "pnpm --filter @ipchun/web build",
    "deploy:web": "pnpm --filter @ipchun/web run deploy",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "autoparse": "tsx tools/autoparse/index.ts"
  },
  "devDependencies": {
    "prettier": "^3.5.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.6.0"
}
